{
  // --- Editor Behavior ---
  "editor.mouseWheelZoom": true, // Zoom with mouse wheel
  "editor.formatOnSave": true, // Auto-format on save
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.fixAll.eslint": "explicit",
  },
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.renderWhitespace": "all", // Show whitespace
  "editor.minimap.enabled": true, // Minimap for code navigation
  "editor.guides.bracketPairs": true, // Highlight matching brackets
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  // --- File Behavior ---
  "files.autoSave": "onWindowChange", // Auto-save when switching windows
  "files.trimTrailingWhitespace": true, // Clean trailing spaces
  "files.insertFinalNewline": true, // End files with newline
  "javascript.updateImportsOnFileMove.enabled": "always",

  // --- Prettier Settings ---
  "prettier.singleQuote": true,
  "prettier.semi": false,
  "prettier.trailingComma": "es5",
  "prettier.printWidth": 80,

  // --- Language-specific Formatter ---
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },

  // --- Terminal ---
  "terminal.integrated.focusAfterRun": true,
  "terminal.integrated.scrollback": 5000, // Keep long history
  "terminal.integrated.cursorStyle": "block",

  // --- Misc Productivity ---
  "workbench.colorTheme": "Default Dark+", // Clean dark theme
  "workbench.iconTheme": "material-icon-theme", // Nice folder/file icons
  "explorer.confirmDelete": false, // Delete without confirmation
  "breadcrumbs.enabled": true, // Show file breadcrumbs
}
